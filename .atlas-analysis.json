{
  "projectType": "cli-tool",
  "projectName": "irtrafficgen",
  "projectDescription": "An Iran-focused HTTPS traffic generator for authorized lab and network testing, sampling targets from embedded V2Ray geosite and geoip datasets.",
  "theme": "aspen",
  "primaryColor": "#f44b34",
  "lightColor": "#ac3324",
  "darkColor": "#3c2c04",
